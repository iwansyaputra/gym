# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration (Laragon MySQL)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=membership_gym
DB_PORT=3306

# JWT Secret
JWT_SECRET=gym_membership_secret_key_2024_very_secure_random_string
JWT_EXPIRES_IN=7d

# Email Configuration (optional)
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password

# NFC Configuration
NFC_AID=A000DADADADADA

# Public URL backend (dipakai untuk callback/redirect payment)
# Contoh lokal: http://192.168.1.10:3000
BACKEND_PUBLIC_URL=http://localhost:3000

# E-Smartlink Payment Gateway
ESMARTLINK_BASE_URL=https://payment-service-sbx.pakar-digital.com
# Username dari E-Smartlink menggunakan email credential
ESMARTLINK_USERNAME=api-smartlink-sbx@your-domain.ac.id
ESMARTLINK_PASSWORD=your_esmartlink_password
ESMARTLINK_EMAIL_CREDENTIAL=your_email_credential_for_signature

# Optional payment settings
ESMARTLINK_CHANNEL=VA_CIMB
ESMARTLINK_PAYMENT_MODE=CLOSE
ESMARTLINK_EXPIRED_TIME=
